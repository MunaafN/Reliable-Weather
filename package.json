{
  "name": "weather-app-monorepo",
  "version": "1.0.0",
  "description": "Beautiful weather app with React frontend and Node.js backend",
  "scripts": {
    "install-all": "npm run install-backend && npm run install-frontend",
    "install-backend": "cd backend && npm install",
    "install-frontend": "cd frontend && npm install",
    "dev": "concurrently \"npm run dev-backend\" \"npm run dev-frontend\"",
    "dev-backend": "cd backend && npm run dev",
    "dev-frontend": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "test": "cd frontend && npm test",
    "setup": "npm run install-all && echo 'Setup complete! Please add your OpenWeatherMap API key to backend/.env'"
  },
  "keywords": [
    "weather",
    "react",
    "nodejs",
    "express",
    "tailwindcss",
    "framer-motion",
    "openweathermap"
  ],
  "author": "Weather App",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.14.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/weather-app.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/weather-app/issues"
  },
  "homepage": "https://github.com/yourusername/weather-app#readme"
}
